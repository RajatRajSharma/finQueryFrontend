# Copy to .env. Base URL of the FinQuery backend API. Production (Render) by default.
VITE_API_BASE_URL=https://finquerybackend.onrender.com

# Evaluation endpoints (/evals, /evals/run) are slow + quota-heavy, so they point
# at a separate/local backend instead of the production free tier.
VITE_EVAL_API_BASE_URL=http://localhost:8000

# Keep-alive: ping /health on an interval so the free-tier backend doesn't sleep.
# Set VITE_KEEPALIVE_ENABLED=false to turn it off; interval is in milliseconds.
VITE_KEEPALIVE_ENABLED=true
VITE_KEEPALIVE_INTERVAL_MS=540000

# How long the chat + uploaded-doc list stay cached in the browser, in
# milliseconds. Default is 1 week (604800000).
VITE_CHAT_CACHE_TTL_MS=604800000
